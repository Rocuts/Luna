# ============================================================
# LangLA – Variables de Entorno
# ============================================================
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local a git.
# ============================================================

# ----- OpenAI -----------------------------------------------
# Requerido. Tu API key de OpenAI.
# Obtén la tuya en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Opcional. Modelo de voz en tiempo real.
# Valor por defecto: gpt-4o-realtime-preview
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
